{
  "name": "autolive",
  "version": "1.0.0",
  "description": "AutoLive - Complete Content Automation Platform for YouTube & TikTok",
  "main": "backend/server.js",
  "author": "AutoLive Team",
  "license": "MIT",
  "private": false,
  "keywords": [
    "youtube",
    "tiktok",
    "automation",
    "content",
    "viral",
    "video",
    "ai"
  ],

  "engines": {
    "node": ">=18"
  },

  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "npm install",
    "test": "jest",
    "lint": "eslint backend/ --ext .js",
    "format": "prettier --write \"backend/**/*.js\"",
    "db:migrate": "node database/migrations/run.js",
    "deploy": "bash scripts/deploy.sh",
    "logs": "tail -f logs/error.log",
    "postinstall": "echo 'AutoLive installed successfully'"
  },

  "dependencies": {
    "@googleapis/youtube": "^8.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.10",
    "socket.io": "^4.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "youtube-dl-exec": "^2.2.2",
    "zod": "^3.22.4"
  },

  "devDependencies": {
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3"
  },
  
  "dependencies": {
  "bull": "^4.12.0",
  "ioredis": "^5.4.0",
  "tiktok-scraper": "^1.0.0",
  "express": "^4.18.0",
  "supertest": "^6.3.3"
  },

  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
