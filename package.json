{
  "name": "autolive",
  "version": "1.0.0",
  "description": "AutoLive - Complete Content Automation Platform for YouTube & TikTok",
  "main": "backend/server.js",
  "author": "AutoLive Team",
  "license": "MIT",
  "private": false,
  "keywords": [
    "youtube",
    "tiktok",
    "automation",
    "content",
    "viral",
    "video",
    "social-media",
    "marketing",
    "analytics",
    "scheduler",
    "uploader",
    "downloader",
    "editor",
    "ai",
    "machine-learning"
  ],
  "homepage": "https://autolive.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/autolive.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/autolive/issues",
    "email": "support@autolive.com"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "prod": "NODE_ENV=production node backend/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:coverage": "jest --coverage --collectCoverageFrom=backend/**/*.js",
    "lint": "eslint backend/ --ext .js",
    "lint:fix": "eslint backend/ --ext .js --fix",
    "format": "prettier --write \"backend/**/*.js\" \"frontend/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"backend/**/*.js\"",
    "db:create": "node scripts/create-db.js",
    "db:drop": "node scripts/drop-db.js",
    "db:migrate": "node database/migrations/run.js",
    "db:migrate:create": "node scripts/create-migration.js",
    "db:seed": "node database/seed.js",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed",
    "build": "echo 'No build step required for backend'",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "clean:full": "rm -rf node_modules package-lock.json logs/* storage/* && npm install",
    "deploy": "bash scripts/deploy.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "logs": "tail -f logs/error.log logs/access.log",
    "logs:error": "tail -f logs/error.log",
    "logs:access": "tail -f logs/access.log",
    "monitor": "pm2 monit",
    "status": "pm2 status",
    "restart": "pm2 restart autolive",
    "stop": "pm2 stop autolive",
    "docker:build": "docker build -t autolive .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prepare": "husky install",
    "validate": "npm run lint && npm run test",
    "postinstall": "echo '✅ Installation complete! Run npm run dev to start development server'"
  },
  "dependencies": {
    "@googleapis/youtube": "^8.0.0",
    "@prisma/client": "^5.0.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "bull-board": "^5.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pm2": "^5.3.0",
    "redis": "^4.6.10",
    "socket.io": "^4.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "youtube-dl-exec": "^2.2.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.1.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/server.js",
      "!**/node_modules/**"
    ]
  }
}
