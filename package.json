{
  "name": "autolive",
  "version": "1.0.0",
  "description": "Automated Video Content Management System for YouTube and TikTok",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "prod": "NODE_ENV=production node backend/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint backend/",
    "lint:fix": "eslint backend/ --fix",
    "format": "prettier --write \"backend/**/*.js\"",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "cleanup": "node scripts/cleanup.js",
    "backup": "node scripts/backup.js",
    "deploy": "bash scripts/deploy.sh"
  },
  "keywords": [
    "youtube",
    "tiktok",
    "automation",
    "video",
    "content",
    "management",
    "ai"
  ],
  "author": "AUTOLIVE Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/speech": "^5.0.0",
    "@google-cloud/storage": "^6.9.0",
    "axios": "^1.3.4",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "ffmpeg-static": "^5.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^11.1.0",
    "google-auth-library": "^8.7.0",
    "googleapis": "^118.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.1",
    "openai": "^3.2.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.5",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "ytdl-core": "^4.11.2"
  },
  "devDependencies": {
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.4",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
