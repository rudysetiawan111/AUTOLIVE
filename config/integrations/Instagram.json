{
  "name": "Instagram Integration",
  "version": "1.3.0",
  "enabled": true,
  "api": {
    "baseUrl": "https://graph.facebook.com/v18.0",
    "authUrl": "https://www.facebook.com/v18.0/dialog/oauth",
    "tokenUrl": "https://graph.facebook.com/v18.0/oauth/access_token",
    "scopes": [
      "instagram_basic",
      "instagram_content_publish",
      "instagram_manage_comments",
      "instagram_manage_insights",
      "pages_read_engagement",
      "pages_manage_posts"
    ],
    "apiVersion": "v18.0"
  },
  "oauth": {
    "clientId": "YOUR_INSTAGRAM_CLIENT_ID",
    "clientSecret": "YOUR_INSTAGRAM_CLIENT_SECRET",
    "redirectUri": "https://autolive.com/auth/instagram/callback",
    "responseType": "code"
  },
  "upload": {
    "maxFileSize": 100000000,
    "maxDuration": 60,
    "minDuration": 3,
    "allowedFormats": [
      "mp4",
      "mov"
    ],
    "allowedImageFormats": [
      "jpg",
      "jpeg",
      "png"
    ],
    "aspectRatios": [
      "1:1",
      "4:5",
      "16:9"
    ],
    "maxCarouselItems": 10,
    "defaultPrivacy": "public",
    "story": {
      "maxDuration": 15,
      "maxFileSize": 4000000
    },
    "reels": {
      "maxDuration": 90,
      "music": true,
      "effects": true
    }
  },
  "analytics": {
    "enabled": true,
    "metrics": [
      "impressions",
      "reach",
      "profile_views",
      "follower_count",
      "email_contacts",
      "phone_call_clicks",
      "text_message_clicks",
      "get_directions_clicks",
      "website_clicks"
    ]
  }
}
