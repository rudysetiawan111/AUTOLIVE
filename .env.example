# AutoLive - Environment Configuration Example
# Copy this file to .env and fill with your values

# ======================
# APPLICATION CONFIG
# ======================
NODE_ENV=development
APP_NAME=AutoLive
APP_URL=http://localhost:3000
PORT=3000
HOST=localhost

# ======================
# DATABASE CONFIG
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autolive_dev
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ======================
# REDIS CONFIG
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================
# JWT & AUTHENTICATION
# ======================
JWT_SECRET=change_this_to_random_string_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_this_to_another_random_string
JWT_REFRESH_EXPIRE=30d
SESSION_SECRET=change_this_to_session_secret
BCRYPT_ROUNDS=10

# ======================
# YOUTUBE API
# ======================
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# ======================
# TIKTOK API
# ======================
TIKTOK_API_KEY=your_tiktok_api_key
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/callback

# ======================
# EMAIL CONFIG
# ======================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM="AutoLive <noreply@yourdomain.com>"
EMAIL_ADMIN=admin@yourdomain.com

# ======================
# STORAGE CONFIG
# ======================
STORAGE_DRIVER=local
STORAGE_PATH=./storage
STORAGE_URL=/storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=ap-southeast-1

# ======================
# FILE UPLOADS
# ======================
MAX_FILE_SIZE=100mb
MAX_VIDEO_SIZE=500mb
ALLOWED_VIDEO_TYPES=mp4,mov,avi,mkv,webm
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
UPLOAD_PATH=./storage/uploads
DOWNLOAD_PATH=./storage/downloads
PROCESSED_PATH=./storage/processed
TEMP_PATH=./storage/temp

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug
LOG_PATH=./logs
LOG_FILE=autolive.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE="Too many requests, please try again later."

# ======================
# FEATURE FLAGS
# ======================
ENABLE_AI_FEATURES=true
ENABLE_AUTOMATION=true
ENABLE_EMAIL_REPORTS=true
ENABLE_VIDEO_PROCESSING=true
ENABLE_SCHEDULER=true
ENABLE_NOTIFICATIONS=true
ENABLE_BACKUP=true

# ======================
# AI & ML CONFIG
# ======================
AI_MODEL_PATH=./ai/models
VIRALITY_THRESHOLD=0.7
TITLE_GENERATOR_ENABLED=true
HASHTAG_GENERATOR_ENABLED=true
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# ======================
# BACKGROUND JOBS
# ======================
QUEUE_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=5000
SCHEDULER_TIMEZONE=Asia/Jakarta
BACKUP_SCHEDULE="0 2 * * *"
CLEANUP_SCHEDULE="0 3 * * 0"

# ======================
# SECURITY
# ======================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
TRUST_PROXY=1
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# ======================
# MONITORING
# ======================
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=AutoLive-Development
METRICS_ENABLED=false
METRICS_PORT=9090

# ======================
# EXTERNAL SERVICES
# ======================
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
CHROME_PATH=/usr/bin/google-chrome

# ======================
# PAYMENT CONFIG
# ======================
STRIPE_KEY=
STRIPE_SECRET=
CURRENCY=IDR

# ======================
# API DOCUMENTATION
# ======================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# ======================
# WEBSOCKET
# ======================
WS_ENABLED=true
WS_PATH=/ws
WS_MAX_CONNECTIONS=1000

