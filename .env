# AutoLive - Environment Configuration
# WARNING: Jangan commit file ini ke repository!

# ======================
# APPLICATION CONFIG
# ======================
NODE_ENV=production
APP_NAME=AutoLive
APP_URL=https://autolive.com
PORT=3000
HOST=0.0.0.0

# ======================
# DATABASE CONFIG
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autolive_prod
DB_USER=autolive_user
DB_PASSWORD=SecureP@ssw0rd123!
DB_POOL_MIN=2
DB_POOL_MAX=10

# ======================
# REDIS CONFIG (for queues & cache)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_DB=0

# ======================
# JWT & AUTHENTICATION
# ======================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-long
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=another-super-secret-refresh-key
JWT_REFRESH_EXPIRE=30d
SESSION_SECRET=session-secret-key-for-encryption
BCRYPT_ROUNDS=10

# ======================
# YOUTUBE API
# ======================
YOUTUBE_API_KEY=AIzaSyDummyKey123456789
YOUTUBE_CLIENT_ID=123456789-abc123.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-dummy-secret-123
YOUTUBE_REDIRECT_URI=https://autolive.com/api/youtube/callback
YOUTUBE_API_URL=https://www.googleapis.com/youtube/v3

# ======================
# TIKTOK API
# ======================
TIKTOK_API_KEY=tiktok_api_key_here
TIKTOK_CLIENT_KEY=aw2e3r4t5y6u7i8o9p0
TIKTOK_CLIENT_SECRET=tiktok_client_secret_here
TIKTOK_REDIRECT_URI=https://autolive.com/api/tiktok/callback
TIKTOK_API_URL=https://open-api.tiktok.com

# ======================
# EMAIL CONFIG
# ======================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@autolive.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM="AutoLive <noreply@autolive.com>"
EMAIL_ADMIN=admin@autolive.com

# ======================
# STORAGE CONFIG
# ======================
STORAGE_DRIVER=local  # local, s3, gcs
STORAGE_PATH=/var/www/autolive/storage
STORAGE_URL=/storage
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET=autolive-uploads
AWS_REGION=ap-southeast-1

# ======================
# FILE UPLOADS
# ======================
MAX_FILE_SIZE=100mb
MAX_VIDEO_SIZE=500mb
ALLOWED_VIDEO_TYPES=mp4,mov,avi,mkv,webm
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
UPLOAD_PATH=./storage/uploads
DOWNLOAD_PATH=./storage/downloads
PROCESSED_PATH=./storage/processed
TEMP_PATH=./storage/temp

# ======================
# LOGGING
# ======================
LOG_LEVEL=info
LOG_PATH=./logs
LOG_FILE=autolive.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE="Too many requests, please try again later."

# ======================
# FEATURE FLAGS
# ======================
ENABLE_AI_FEATURES=true
ENABLE_AUTOMATION=true
ENABLE_EMAIL_REPORTS=true
ENABLE_VIDEO_PROCESSING=true
ENABLE_SCHEDULER=true
ENABLE_NOTIFICATIONS=true
ENABLE_BACKUP=true

# ======================
# AI & ML CONFIG
# ======================
AI_MODEL_PATH=./ai/models
VIRALITY_THRESHOLD=0.7
TITLE_GENERATOR_ENABLED=true
HASHTAG_GENERATOR_ENABLED=true
OPENAI_API_KEY=sk-dummy-openai-key
OPENAI_MODEL=gpt-4

# ======================
# BACKGROUND JOBS
# ======================
QUEUE_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=5000
SCHEDULER_TIMEZONE=Asia/Jakarta
BACKUP_SCHEDULE="0 2 * * *"  # Every day at 2 AM
CLEANUP_SCHEDULE="0 3 * * 0"  # Every Sunday at 3 AM

# ======================
# SECURITY
# ======================
CORS_ORIGIN=https://autolive.com,https://admin.autolive.com
CORS_CREDENTIALS=true
TRUST_PROXY=1
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# ======================
# MONITORING
# ======================
SENTRY_DSN=https://dummy@sentry.io/123456
NEW_RELIC_LICENSE_KEY=your-new-relic-key
NEW_RELIC_APP_NAME=AutoLive-Production
METRICS_ENABLED=true
METRICS_PORT=9090

# ======================
# EXTERNAL SERVICES
# ======================
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
CHROME_PATH=/usr/bin/google-chrome

# ======================
# PAYMENT CONFIG (if applicable)
# ======================
STRIPE_KEY=pk_live_dummy_key
STRIPE_SECRET=sk_live_dummy_secret
CURRENCY=IDR

# ======================
# API DOCUMENTATION
# ======================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# ======================
# WEBSOCKET
# ======================
WS_ENABLED=true
WS_PATH=/ws
WS_MAX_CONNECTIONS=1000

